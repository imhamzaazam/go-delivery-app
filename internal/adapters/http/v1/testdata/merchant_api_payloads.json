{
  "headers": {
    "content_type": "application/json",
    "authorization": "Bearer {{access_token}}"
  },
  "create_merchant": {
    "request": {
      "name": "Suijing",
      "ntn": "NTN-SUIJING-001",
      "address": "Jauhar",
      "category": "restaurant",
      "contact_number": "+92123123"
    },
    "expected_response": {
      "address": "Jauhar",
      "category": "restaurant",
      "contact_number": "+92123123",
      "id": "{{merchant_id}}",
      "name": "Suijing",
      "ntn": "NTN-SUIJING-001"
    }
  },
  "bootstrap_actor": {
    "request": {
      "full_name": "Merchant Owner",
      "email": "merchant.owner.payload@test.local",
      "password": "Password#123",
      "role": "merchant"
    }
  },
  "login_actor": {
    "request": {
      "merchant_id": "{{merchant_id}}",
      "email": "merchant.owner.payload@test.local",
      "password": "Password#123"
    }
  },
  "update_merchant": {
    "request": {
      "name": "Suijing Prime",
      "ntn": "NTN-SUIJING-002",
      "address": "Clifton",
      "category": "restaurant",
      "contact_number": "+92999888"
    },
    "expected_response": {
      "address": "Clifton",
      "category": "restaurant",
      "contact_number": "+92999888",
      "created_at": "{{created_at}}",
      "id": "{{merchant_id}}",
      "name": "Suijing Prime",
      "ntn": "NTN-SUIJING-002",
      "updated_at": "{{updated_at}}"
    }
  },
  "get_merchant": {
    "expected_response": {
      "address": "Clifton",
      "category": "restaurant",
      "contact_number": "+92999888",
      "created_at": "{{created_at}}",
      "id": "{{merchant_id}}",
      "name": "Suijing Prime",
      "ntn": "NTN-SUIJING-002",
      "updated_at": "{{updated_at}}"
    }
  },
  "list_merchants": {
    "expected_response": [
      {
        "address": "Clifton",
        "category": "restaurant",
        "contact_number": "+92999888",
        "created_at": "{{created_at}}",
        "id": "{{merchant_id}}",
        "name": "Suijing Prime",
        "ntn": "NTN-SUIJING-002",
        "updated_at": "{{updated_at}}"
      }
    ]
  }
}